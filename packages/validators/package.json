{
  "name": "@better-sslcommerz/validators",
  "version": "0.2.0",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "files": [
    "dist"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "import": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.js"
      },
      "require": {
        "types": "./dist/index.d.ts",
        "default": "./dist/index.cjs"
      }
    }
  },
  "license": "MIT",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsdown && tsc -p tsconfig.build.json",
    "clean": "git clean -xdf .cache .turbo dist node_modules",
    "dev": "tsdown --no-clean",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "typecheck": "tsc --noEmit --emitDeclarationOnly false"
  },
  "dependencies": {
    "zod": "catalog:"
  },
  "devDependencies": {
    "@better-sslcommerz/eslint-config": "workspace:*",
    "@better-sslcommerz/prettier-config": "workspace:*",
    "@better-sslcommerz/tsconfig": "workspace:*",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "tsdown": "0.14.1",
    "typescript": "catalog:"
  },
  "prettier": "@better-sslcommerz/prettier-config"
}
