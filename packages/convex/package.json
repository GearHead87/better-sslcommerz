{
  "name": "@better-sslcommerz/convex",
  "private": true,
  "type": "module",
  "exports": {
    ".": {
      "types": "./convex/_generated/api.d.ts",
      "default": "./convex/_generated/api.js"
    },
    "./dataModel": {
      "types": "./convex/_generated/dataModel.d.ts"
    },
    "./server": {
      "types": "./convex/_generated/server.d.ts",
      "default": "./convex/_generated/server.js"
    },
    "./env": "./env.ts",
    "./package.json": "./package.json"
  },
  "license": "MIT",
  "scripts": {
    "clean": "git clean -xdf .cache .turbo dist node_modules convex/_generated",
    "dev": "convex dev --typecheck-components",
    "deploy": "convex deploy",
    "format": "prettier --check . --ignore-path ../../.gitignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@t3-oss/env-core": "catalog:",
    "convex": "catalog:",
    "zod": "catalog:"
  },
  "devDependencies": {
    "@better-sslcommerz/eslint-config": "workspace:*",
    "@better-sslcommerz/prettier-config": "workspace:*",
    "@better-sslcommerz/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:"
  },
  "prettier": "@better-sslcommerz/prettier-config"
}
