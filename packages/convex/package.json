{
  "name": "@better-sslcommerz/convex",
  "version": "0.2.0",
  "description": "A SSLCommerz component for Convex.",
  "type": "module",
  "files": [
    "dist",
    "src",
    "convex.config.js"
  ],
  "exports": {
    "./package.json": "./package.json",
    ".": {
      "types": "./dist/client/index.d.ts",
      "default": "./dist/client/index.js"
    },
    "./react": {
      "types": "./dist/react/index.d.ts",
      "default": "./dist/react/index.js"
    },
    "./test": "./src/test.ts",
    "./_generated/component.js": {
      "types": "./dist/component/_generated/component.d.ts"
    },
    "./convex.config": {
      "types": "./dist/component/convex.config.d.ts",
      "default": "./dist/component/convex.config.js"
    },
    "./convex.config.js": {
      "types": "./dist/component/convex.config.d.ts",
      "default": "./dist/component/convex.config.js"
    }
  },
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/GearHead87/better-sslcommerz",
    "directory": "packages/convex"
  },
  "bugs": {
    "url": "https://github.com/GearHead87/better-sslcommerz/issues"
  },
  "homepage": "https://github.com/GearHead87/better-sslcommerz#readme",
  "publishConfig": {
    "access": "public"
  },
  "types": "./dist/client/index.d.ts",
  "module": "./dist/client/index.js",
  "scripts": {
    "build": "tsc --project ./tsconfig.build.json",
    "build:codegen": "convex codegen --component-dir ./src/component && pnpm run build",
    "clean": "git clean -xdf .cache .turbo dist node_modules *.tsbuildinfo",
    "dev": "convex dev --typecheck-components",
    "format": "prettier --check . --ignore-path ../../.gitignore --ignore-path ./.prettierignore",
    "lint": "eslint --flag unstable_native_nodejs_ts_config",
    "test": "vitest run --typecheck",
    "test:watch": "vitest --typecheck",
    "typecheck": "tsc --noEmit"
  },
  "peerDependencies": {
    "convex": "^1.31.6",
    "react": "^18 || ^19"
  },
  "peerDependenciesMeta": {
    "react": {
      "optional": true
    }
  },
  "dependencies": {
    "@better-sslcommerz/sdk": "workspace:^"
  },
  "devDependencies": {
    "@better-sslcommerz/eslint-config": "workspace:*",
    "@better-sslcommerz/prettier-config": "workspace:*",
    "@better-sslcommerz/tsconfig": "workspace:*",
    "@types/node": "catalog:",
    "convex": "catalog:",
    "convex-test": "0.0.41",
    "eslint": "catalog:",
    "prettier": "catalog:",
    "typescript": "catalog:",
    "vite": "catalog:",
    "vitest": "3.2.4"
  },
  "prettier": "@better-sslcommerz/prettier-config"
}
